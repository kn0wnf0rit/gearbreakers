{
  "name": "gearbreakers",
  "version": "0.1.0",
  "description": "Gearbreakers - A steampunk-dystopian turn-based RPG in the browser",
  "type": "module",
  "scripts": {
    "dev": "npx http-server . -p 8080 -c-1",
